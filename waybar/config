{
    "layer": "top",
    "position": "top",
    "height": 20,

    //"width": 1280, // Waybar width

    "spacing": 4, // Gaps between modules (4px)


    "modules-left": [
        "hyprland/workspaces",
//        "custom/separator",
//        "custom/uptime",
        "custom/separator",
        "hyprland/language",
        "custom/separator",
        "custom/dunst",
        "custom/separator",
        "mpris"
    ],

    "modules-center": [
        "clock",
    ],

    "modules-right": [
        "disk",
        "custom/separator",
        "backlight",
        "custom/separator",
        "pulseaudio",
        "custom/separator",
        "battery",
        "custom/separator",
        "memory",
        "custom/separator",
        "cpu",
        "custom/separator",
        "temperature",
        "custom/separator",
        "network",
        "custom/separator",
        "tray",
    ],

    "custom/separator": {
        "format": "|",
    },

    "custom/dunst": {
        "exec": "~/.config/waybar/scripts/dunst.sh",
        "on-click": "dunstctl set-paused toggle",
        "restart-interval": 1,
    },

    "custom/uptime": {
        "exec": "uptime -p | sed -E 's/up //; s/([0-9]+) hours?/\\1h/; s/([0-9]+) minutes?/\\1m/'",
        "interval": 60,
        "format": "у°ә“   {}",
    },

    "mpris": {
    "format": "о°ӣ ",
    "format-alt": "{player_icon} {artist} - {title}",
    "on-click": "mode",
    "format-paused": "пҒҢ",
    "format-stopped": "о°ӣ",
    "player-icons": {
        "default": "о°ӣ",
    },
    "interval": 1,
    "max-length": 50,
    "tooltip": true
},


    // Modules configuration


    "disk" : {
        "format": "({percentage_used}%) пҮҖ"
    },

    "hyprland/workspaces": {
        "all-outputs": true,
        "disable-scroll": false,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{id}",
        "persistent-workspaces": {
             "*": 0,
       }
    },


    "hyprland/language": {
        "format": "{}",
        "format-en": "us",
        "format-ru": "ru",
        "keyboard-name": "at-translated-set-2-keyboard"
    },

    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "пҖЈ",
            "unlocked": "пӮң"
        }
    },

    "hyprland/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },



    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пҒ®",
            "deactivated": "пҒ°"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 5
    },


        "clock": {
        "interval": 1,
        "format": "{:%H:%M:%S}",
        "format-alt": "{:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "year",
                    "mode-mon-col"  : 2,
                    "weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "on-click-right": "mode",
                    "format": {
                              "months":     "<span color='#ffead3'><b>{}</b></span>",
                              "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                              "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-click-forward": "tz_up",
                    "on-click-backward": "tz_down",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },
    "cpu": {
        "format": "{usage}% пӢӣ",
        "tooltip": false,
        "interval": 1,
    },
    "memory": {
        "format": "{}% у°Қӣ",
        "interval": 1,
    },
    "temperature": {
        // "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}В°C {icon}",
        "format": "{temperatureC}В°C {icon}",
        "format-icons": ["пқ«", "пӢү", "пқ©"],
        "interval": 1,
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 15,
            "critical": 5
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% п—§",
        "format-plugged": "{capacity}% пҮҰ",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["у°ӮҺ", "уұҠЎ", "уұҠў", "уұҠЈ"],
        "interval": 1,
    },


    "network": {
        "interface": "wlp0s20f3", // (Optional) To force the use of this interface
        "format-wifi": "({signalStrength}%) пҮ«",
        "tooltip-format-wifi": "{ifname}: {ipaddr}/{cidr} пҮ«",
        "format-ethernet": "{ipaddr}/{cidr} пһ–",
        "tooltip-format": "{ifname} via {gwaddr} пһ–",
        "format-linked": "{ifname} (No IP) пһ–",
        "format-disconnected": "пҒІ",
        "format-alt": "{essid}: ({bandwidthDownBits} {bandwidthUpBits}) пҮ«",
        "interval": 1,
    },


    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}пҠ” {format_source}",
        "format-bluetooth-muted": "пҡ© {icon}пҠ” {format_source}",
        "format-muted": "пҡ© {format_source}",
        "format-source": "{volume}% п„°",
        "format-source-muted": "п„ұ",
        "format-icons": {
            "headphone": "пҖҘ",
            "hands-free": "пҖҘ ",
            "headset": "пҖҘ ",
            "phone": "пӮ•",
            "portable": "пӮ•",
            "car": "пҶ№",
            "default": ["пҖҰ", "пҖ§", "пҖЁ"]
        },
        "on-click": "pavucontrol"
    },
}

