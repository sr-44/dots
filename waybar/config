{
    "layer": "top",
    "position": "top",
    "height": 20,
    "spacing": 4,

    "modules-left": [
        "niri/workspaces",
        "custom/separator",
        "niri/language",
        "custom/separator",
        "custom/swaync",
        "custom/separator",
        "mpris"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "idle_inhibitor",
        "custom/separator",
        "backlight",
        "custom/separator",
        "pulseaudio",
        "custom/separator",
        "battery",
        "custom/separator",
        "memory",
        "custom/separator",
        "cpu",
        "custom/separator",
        "temperature",
        "custom/separator",
        "network",
        "custom/separator",
        "tray"
