    "custom/separator": {
        "format": "|",
    },

    "custom/dunst": {
        "exec": "~/.config/waybar/scripts/dunst.sh",
        "on-click": "dunstctl set-paused toggle",
        "restart-interval": 1,
    },

    "custom/uptime": {
        "exec": "uptime -p | sed -E 's/up //; s/([0-9]+) hours?/\\1h/; s/([0-9]+) minutes?/\\1m/'",
        "interval": 60,
        "format": "¾░║ô   {}",
    },

    "mpris": {
    "format": "¯░ø ",
    "format-alt": "{player_icon} {artist} - {title}",
    "on-click": "mode",
    "format-paused": "´üî",
    "format-stopped": "¯░ø",
    "player-icons": {
        "default": "¯░ø",
    },
    "interval": 1,
    "max-length": 50,
    "tooltip": true
},


    // Modules configuration

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "¾░àÂ",
            "deactivated": "¾░¥¬"
        },
        "tooltip-format-activated": "idle inhibitor: on",
        "tooltip-format-deactivated": "idle inhibitor: off"
    },

    "hyprland/workspaces": {
        "all-outputs": true,
        "disable-scroll": false,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{id}",
        "persistent-workspaces": {
             "*": 0,
       }
    },


    "hyprland/language": {
        "format": "{}",
